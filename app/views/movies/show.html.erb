<p style="color: green"><%= notice %></p>

<%= render @movie %>

<div>
  <%# if can? :update, @movie %>
    <%= link_to "Edit this movie", edit_movie_path(@movie) %> |
  <%# end %>
  <%= link_to "Back to movies", movies_path, class: 'btn btn-primary' %>
  <%# if can? :delete, @movie %>
    <%= button_to "Destroy this movie", @movie, method: :delete, class: 'btn btn-danger' %>
  <%# end %>
</div>

<% content_for :title, "Movies" %>

<h1>Movies</h1>

<% if can? :create, Movie %>
  <%= link_to "New movie", new_movie_path, class: 'btn btn-info' %>
<% end %>

<br>

<div id="movies" class="row align-items-center">
  <% @movies.each do |movie| %>
    <div class="col-auto">
      <%= render movie %>
      <p>
        <% if can? :read, movie %>
          <%= link_to "Show this movie", movie %>
        <% end %>
      </p>
    </div>
  <% end %>
</div>
